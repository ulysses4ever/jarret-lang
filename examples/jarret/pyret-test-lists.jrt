// pyret-test-lists.jrt -- behavioural port of tests/pyret/tests/test-lists.arr.
//
// Goal: exercise the same list-operation semantics that Pyret's own
// regression suite covers, through the Jarret translator. If something
// here regresses we want to know.
//
// Blocks skipped (use features Jarret does not have):
//   - `member` ref/box parts and `member-now*` / `member-always*`
//   - `shuffle` (uses tuples + `for fold` comprehension)
//   - `stable sort` (raw-array, tuples, anonymous `{(p): ...}` lambdas)
//   - `distinct` (uses roughnum `~1` literals)

@Check void testListMethods() {
    [list: 1].push(0) is [list: 0, 1];
    [list: 1, 2, 3, 4, 5, 6].take(3) is [list: 1, 2, 3];
    [list: 1, 2, 3, 4, 5, 6].drop(3) is [list: 4, 5, 6];
    [list: 1, 2, 3].get(0) is 1;
    [list: ].get(0) raises "";
    [list: 1, 2, 3].set(0, 5) is [list: 5, 2, 3];
    [list: ].set(0, 5) raises "";
}

@Check void testGet() {
    lists.get([list: 1, 2, 3], 0) is 1;
    lists.get([list: ], 0) raises "";
}

@Check void testSet() {
    lists.set([list: 1, 2, 3], 0, 5) is [list: 5, 2, 3];
    lists.set([list: 1, 2, 3], 5, 5) raises "";
}

@Check void testRange() {
    lists.range(0, 0) is [list: ];
    lists.range(0, 1) is [list: 0];
    lists.range(-5, 5) is [list: -5, -4, -3, -2, -1, 0, 1, 2, 3, 4];
    lists.range(0, 1/2) raises "Integer";
}

@Check void testRepeat() {
    lists.repeat(0, 10) is empty;
    lists.repeat(3, -1) is [list: -1, -1, -1];
    lists.repeat(1, "foo") is link("foo", empty);
}

@Check void testReverse() {
    lists.reverse([list: ]) is [list: ];
    lists.reverse([list: 1, 3]) is [list: 3, 1];
    lists.reverse([list: 1, 3, 2]) is [list: 2, 3, 1];
}

@Check void testFilter() {
    filter((e) -> e > 5, [list: -1, 1]) is [list: ];
    filter((e) -> e > 0, [list: -1, 1]) is [list: 1];
}

@Check void testPartition() {
    partition((e) -> e > 0, [list: -1, 1])
        is {is-true: [list: 1], is-false: [list: -1]};
    partition((e) -> e > 5, [list: -1, 1])
        is {is-true: [list: ], is-false: [list: -1, 1]};
    partition((e) -> e < 5, [list: -1, 1])
        is {is-true: [list: -1, 1], is-false: [list: ]};
}

@Check void testFind() {
    find((elt) -> elt > 1, [list: 1, 2, 3]) is some(2);
    find((elt) -> elt > 4, [list: 1, 2, 3]) is none;
    find((elt) -> true, [list: "find-me", "miss-me"]) is some("find-me");
    find((elt) -> true, empty) is none;
    find((elt) -> false, [list: "miss-me"]) is none;
    find((elt) -> false, empty) is none;
}

@Check void testSplitAt() {
    var List<Number> oneFour = link(1, link(2, link(3, link(4, empty))));
    split-at(0, oneFour) is {prefix: empty, suffix: oneFour};
    split-at(4, oneFour) is {prefix: oneFour, suffix: empty};
    split-at(2, oneFour)
        is {prefix: link(1, link(2, empty)), suffix: link(3, link(4, empty))};
    split-at(-1, oneFour) raises "Invalid index";
    split-at(1.35, oneFour) raises "Invalid index";
    split-at(5, oneFour) raises "Index too large";
}

@Check void testAny() {
    any((n) -> n > 1, [list: 1, 2, 3]) is true;
    any((n) -> n > 3, [list: 1, 2, 3]) is false;
    any((x) -> true, empty) is false;
    any((x) -> false, empty) is false;
}

@Check void testAll() {
    lists.all((n) -> n > 1, [list: 1, 2, 3]) is false;
    lists.all((n) -> n <= 3, [list: 1, 2, 3]) is true;
    lists.all((x) -> true, empty) is true;
    lists.all((x) -> false, empty) is true;
}

@Check void testFold() {
    fold((acc, cur) -> acc, 1, [list: 1, 2, 3, 4]) is 1;
    fold((acc, cur) -> cur, 1, [list: 1, 2, 3, 4]) is 4;
    fold((acc, cur) -> acc + cur, 0, [list: 1, 2, 3, 4]) is 10;
    fold((lst, elt) -> link(elt, lst), empty, [list: 1, 2, 3]) is [list: 3, 2, 1];
}

@Check void testFoldr() {
    lists.foldr((lst, elt) -> link(elt, lst), empty, [list: 1, 2, 3])
        is [list: 1, 2, 3];
}

@Check void testFold2() {
    fold2((x, y, z) -> x - y - z, 6, [list: 1, 1, 1], [list: 1, 1, 1]) is 0;
}

@Check void testStringHelper() {
    lists.join-str([list: "a", "b"], ",") is "a,b";
    lists.join-str([list: "", "", ""], "") is "";
    lists.join-str([list: "", "a", ""], ",") is ",a,";
    lists.join-str([list: ], ",") is "";
    lists.join-str([list: "a"], ",") is "a";
    lists.join-str([list: "a", "b", "c", "d", "e"], "  ") is "a  b  c  d  e";
}

@Check void testSort() {
    lists.sort([list: 1, 5, 6, 2, 3]) is [list: 1, 2, 3, 5, 6];
    lists.sort([list: "dog", "Dog", "DOG"]) is [list: "DOG", "Dog", "dog"];
}

@Check void testSortByRecords() {
    lists.sort-by(
        [list:
            {name: "Bob",  age: 22},
            {name: "Amy",  age: 5},
            {name: "Bob",  age: 17},
            {name: "Joan", age: 43},
            {name: "Alex", age: 3}],
        (p1, p2) -> p1.age < p2.age,
        (p1, p2) -> p1.age == p2.age)
    is
    [list:
        {name: "Alex", age: 3},
        {name: "Amy",  age: 5},
        {name: "Bob",  age: 17},
        {name: "Bob",  age: 22},
        {name: "Joan", age: 43}];
}

@Check void testMoreUtilities() {
    lists.last([list: 1]) is 1;
    lists.last([list: 1, 2, 3, 4, 5, 6, 7]) is 7;
    lists.append([list: 1, 2, 3], [list: 4, 5, 6]) is [list: 1, 2, 3, 4, 5, 6];
    lists.push(empty, 1) is link(1, empty);
}

@Check void testBuild() {
    lists.build-list((x) -> x * 2, 6) is [list: 0, 2, 4, 6, 8, 10];
    lists.build-list((x) -> tostring(x), 2) is [list: "0", "1"];
    lists.build-list((x) -> tostring(x), 0) is empty;
    lists.build-list((x) -> x * 2, -1) raises "NumNonNegative";
    lists.build-list("not-a-function", -1) raises "Function";
}
